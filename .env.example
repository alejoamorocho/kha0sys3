# Kha0sys3 — credenciales y secretos (PLANTILLA)
#
# Copia este archivo a .env y rellena los valores reales.
# .env esta en .gitignore — NUNCA commitear.
#
# Orden de precedencia para carga de credenciales:
#   1. variables de entorno del proceso (export FOO=bar)
#   2. .env en raiz del repo
#   3. config/broker.yaml y config/telegram.yaml (legacy, ya gitignored)

# ─── VPS Windows Server (WinRM) ────────────────────────────────
VPS_IP=
VPS_PORT=5986
VPS_USER=
VPS_PASS=

# ─── MetaTrader 5 (Vantage) ────────────────────────────────────
MT5_LOGIN=
MT5_PASSWORD=
MT5_SERVER=

# ─── Telegram bot ──────────────────────────────────────────────
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_GROUP_CHAT_ID=
